<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login</title>
  <link rel="stylesheet" href="/css/style.css">
</head>

<body>
  <h1>Login </h1>
  <% if(locals.err){ %>
    <div class="error-block">
      <p>
        <%= err %>
      </p>
    </div>

    <% }%>
      <form action="/login" method="POST"><br>
        <label for="email">Email</label><br>
        <input type="email" name="email" class="<%=locals.errfield && errfield.includes('email')?'input-error':''%>"
          value="
    <%=locals.values && locals.values.email?locals.values.email :''%>
    "><br>
        <label for="password">password</label><br>
        <input type="password" name="password"
          class="<%=locals.errfield && errfield.includes('password')?'input-error':''%>"
           value="<%=locals.values && locals.values.password ?locals.values.password :''%>"><br><br>
        <input type="submit" value="login">
      </form>
</body>

</html>